# ── Brain selection ────────────────────────────────────────────────
# Which LLM to use as the brain. Default: claude.
# Set BRAIN=claude|gemini|openai (uncomment openai in agent.ts first)
# BRAIN=claude

# ── API keys (provide the one matching your BRAIN) ─────────────────
# Anthropic — get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Google Gemini — get one at https://aistudio.google.com/app/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# OpenAI (only if you uncomment the openai branch in agent.ts)
# Requires also: npm install @ai-sdk/openai
# OPENAI_API_KEY=sk-...

# ── Agent identity ─────────────────────────────────────────────────
# Email used to look up your Slack user
# MY_EMAIL=joseph.siyi@gmail.com

# ── Zapier auth ────────────────────────────────────────────────────
# Default: uses `npx zapier-sdk login` token cached on this machine.
# If running headless (CI / server), generate client credentials instead:
#   npx zapier-sdk create-client-credentials
# ZAPIER_CREDENTIALS_CLIENT_ID=
# ZAPIER_CREDENTIALS_CLIENT_SECRET=

# ── Dev / Testing ──────────────────────────────────────────────────
# DRY_RUN=1 → uses MockLanguageModelV3 + mock Zapier hands. No API calls.
#             Useful for verifying the architecture without burning quota.
# DRY_RUN=1
